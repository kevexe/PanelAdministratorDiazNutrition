<script>
    // Before/After Slider
    document.addEventListener('DOMContentLoaded', function() {
        const container = document.querySelector('.slider-container');
        if(!container) return;
        
        const slider = document.getElementById('slider-handle');
        const overlay = document.getElementById('slider-overlay');
        
        let isDragging = false;

        container.addEventListener('mousedown', (e) => {
            isDragging = true;
            updateSlider(e);
        });
        
        window.addEventListener('mouseup', () => {
            isDragging = false;
        });
        
        window.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            updateSlider(e);
        });
        
        container.addEventListener('touchstart', (e) => {
            isDragging = true;
            updateSlider(e.touches[0]);
        });
        
        window.addEventListener('touchend', () => {
            isDragging = false;
        });
        
        window.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            updateSlider(e.touches[0]);
        });

        function updateSlider(e) {
            const rect = container.getBoundingClientRect();
            let x = e.clientX - rect.left;
            
            if (x < 0) x = 0;
            if (x > rect.width) x = rect.width;
            
            const percentage = (x / rect.width) * 100;
            
            overlay.style.width = `${100 - percentage}%`;
            slider.style.left = `${percentage}%`;
        }

        // Initialize Charts
        Chart.defaults.color = '#849495';
        Chart.defaults.font.family = 'Inter';

        // Radar Chart
        const radarCtx = document.getElementById('radarChart');
        if(radarCtx) {
            new Chart(radarCtx, {
                type: 'radar',
                data: {
                    labels: ['Tricipital', 'Subescapular', 'Bicipital', 'Cresta Iliaca', 'Supraespinal', 'Abdominal', 'Muslo'],
                    datasets: [
                        {
                            label: 'Inicial (15 Ene)',
                            data: [12, 14, 8, 16, 18.5, 22, 15],
                            backgroundColor: 'rgba(255, 255, 255, 0.05)',
                            borderColor: '#849495',
                            pointBackgroundColor: '#849495',
                            borderWidth: 1,
                            pointRadius: 3
                        },
                        {
                            label: 'Final (15 Jun)',
                            data: [8.5, 10, 6, 11, 12, 14, 12],
                            backgroundColor: 'rgba(0, 242, 255, 0.2)',
                            borderColor: '#00f2ff',
                            pointBackgroundColor: '#00f2ff',
                            pointBorderColor: '#fff',
                            borderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            angleLines: { color: 'rgba(255, 255, 255, 0.1)' },
                            grid: { color: 'rgba(255, 255, 255, 0.1)' },
                            pointLabels: {
                                color: '#ffffff',
                                font: { size: 10, family: 'Inter' }
                            },
                            ticks: { display: false, min: 0, max: 25 }
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(13, 21, 21, 0.9)',
                            titleColor: '#fff',
                            bodyColor: '#00f2ff',
                            borderColor: 'rgba(0, 242, 255, 0.3)',
                            borderWidth: 1,
                            padding: 10,
                            displayColors: false
                        }
                    }
                }
            });
        }

        // Line Chart
        const lineCtx = document.getElementById('lineChart');
        if(lineCtx) {
            new Chart(lineCtx, {
                type: 'line',
                data: {
                    labels: ['Oct', 'Nov', 'Dic', 'Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Peso Corporal (kg)',
                        data: [82, 81.5, 80.8, 80.0, 78.5, 77.2, 76.0, 75.1, 74.5],
                        borderColor: '#00f2ff',
                        backgroundColor: 'rgba(0, 242, 255, 0.1)',
                        borderWidth: 2,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#080f10',
                        pointBorderColor: '#00f2ff',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { color: '#849495', font: { size: 10 } }
                        },
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { color: '#849495', font: { size: 10 } }
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(13, 21, 21, 0.9)',
                            titleColor: '#fff',
                            bodyColor: '#00f2ff',
                            borderColor: 'rgba(0, 242, 255, 0.3)',
                            borderWidth: 1,
                            padding: 10,
                            displayColors: false
